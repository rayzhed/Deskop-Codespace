{
  "name": "Codespace Desktop",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  "postCreateCommand": "bash .devcontainer/bootstrap.sh",
  "postAttachCommand": "bash -lc '.devcontainer/install-desktop.sh'",

  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "noVNC",
      "onAutoForward": "openBrowser"
    }
  },

  "runArgs": [
    "--cap-add=NET_ADMIN"
  ]
}
